{
  "permissions": {
    "allow": [],
    "deny": [
      "Read(auth.json)",
      "Read(**/auth.json)",
      "Read(storage/oauth-*.key)",
      "Read(**/storage/oauth-*.key)",
      "Read(storage/*.key)",
      "Read(**/storage/*.key)",
      "Read(*secrets*)",
      "Read(**/*secrets*)",
      "Read(*credential*)",
      "Read(**/*credential*)",
      "Read(*credentials*)",
      "Read(**/*credentials*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(auth.json)",
      "Edit(**/auth.json)",
      "Edit(storage/*.key)",
      "Edit(**/storage/*.key)",
      "Edit(*secret*)",
      "Edit(**/*secret*)",
      "Edit(*credential*)",
      "Edit(**/*credential*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "If this is a git push, did the appropriate tests, linting, analysis, coverage, and checks run? $ARGUMENTS",
            "if": "Bash(git *)"
          },
          {
            "type": "agent",
            "prompt": "If this is a git push, did the users last message authorize running a git push right now? $ARGUMENTS",
            "if": "Bash(git *)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/play-sound.sh\"",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\""
  },
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "disableClaudeAiConnectors": true,
  "outputStyle": "efficient",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": false
}
