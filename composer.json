{
  "name": "jean-pierre-gassin/ai-context",
  "description": "Portable AI agent context, skills, and role guidance for software projects.",
  "type": "library",
  "license": "MIT",
  "bin": [
    "bin/ai-context"
  ],
  "autoload": {
